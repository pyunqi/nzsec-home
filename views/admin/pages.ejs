<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NZSEC Admin — Pages</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f1f5f9;
      color: #0f172a;
      font-size: 14px;
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ---- Header ---- */
    .header {
      background: #0f3460;
      color: #fff;
      padding: 0 32px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 10;
      flex-shrink: 0;
    }
    .header-logo { font-size: 18px; font-weight: 800; letter-spacing: -0.5px; }
    .header-nav { display: flex; gap: 4px; align-items: center; }
    .header-nav a {
      font-size: 13px;
      font-weight: 500;
      padding: 6px 14px;
      border-radius: 6px;
      cursor: pointer;
      text-decoration: none;
      color: rgba(255,255,255,0.7);
      transition: background 0.2s, color 0.2s;
    }
    .header-nav a:hover { background: rgba(255,255,255,0.15); color: #fff; }
    .header-nav a.active { background: rgba(255,255,255,0.2); color: #fff; }
    .header-actions { display: flex; gap: 12px; align-items: center; }
    .header-actions a, .header-actions button {
      font-family: inherit;
      font-size: 13px;
      font-weight: 500;
      padding: 6px 16px;
      border-radius: 6px;
      cursor: pointer;
      text-decoration: none;
      border: none;
      transition: background 0.2s;
    }
    .btn-preview { background: rgba(255,255,255,0.15); color: #fff; }
    .btn-preview:hover { background: rgba(255,255,255,0.25); }
    .btn-logout { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }
    .btn-logout:hover { background: rgba(255,255,255,0.2); }

    /* ---- Save banner ---- */
    .save-banner {
      background: #f0fdf4;
      border-bottom: 1px solid #86efac;
      color: #15803d;
      padding: 10px 32px;
      font-weight: 500;
      flex-shrink: 0;
    }

    /* ---- Two-column layout ---- */
    .workspace {
      display: grid;
      grid-template-columns: 280px 1fr;
      flex: 1;
      overflow: hidden;
    }

    /* ---- Left: Page Tree ---- */
    .sidebar {
      background: #fff;
      border-right: 1px solid #e2e8f0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .sidebar-header {
      padding: 16px 16px 12px;
      font-weight: 700;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #64748b;
      border-bottom: 1px solid #f1f5f9;
      flex-shrink: 0;
    }
    .tree {
      flex: 1;
      overflow-y: auto;
      padding: 8px 0;
    }
    .tree-item {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 6px;
      margin: 1px 8px;
      cursor: default;
      transition: background 0.15s;
    }
    .tree-item:hover { background: #f8fafc; }
    .tree-item.active { background: #eff6ff; }
    .tree-item-icon { font-size: 13px; flex-shrink: 0; }
    .tree-item-title {
      flex: 1;
      font-size: 13px;
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: #1e293b;
    }
    .tree-item.active .tree-item-title { color: #2563eb; }
    .tree-item-slug {
      font-size: 11px;
      color: #94a3b8;
      white-space: nowrap;
    }
    .tree-item-actions {
      display: flex;
      gap: 2px;
      opacity: 0;
      transition: opacity 0.15s;
    }
    .tree-item:hover .tree-item-actions { opacity: 1; }
    .tree-item.active .tree-item-actions { opacity: 1; }
    .tree-btn {
      font-size: 11px;
      padding: 2px 6px;
      border-radius: 4px;
      border: 1px solid #e2e8f0;
      background: #fff;
      color: #475569;
      cursor: pointer;
      text-decoration: none;
      font-family: inherit;
      transition: background 0.15s;
      white-space: nowrap;
    }
    .tree-btn:hover { background: #f1f5f9; }
    .tree-btn.delete-btn { color: #ef4444; border-color: #fecaca; }
    .tree-btn.delete-btn:hover { background: #fff5f5; }

    /* ---- New page form ---- */
    .new-page-form {
      padding: 12px 16px;
      border-top: 1px solid #f1f5f9;
      flex-shrink: 0;
    }
    .new-page-form-title {
      font-size: 12px;
      font-weight: 600;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 10px;
    }
    .new-page-form input {
      display: block;
      width: 100%;
      padding: 6px 10px;
      border: 1px solid #e2e8f0;
      border-radius: 6px;
      font-family: inherit;
      font-size: 13px;
      margin-bottom: 6px;
      background: #f8fafc;
      transition: border-color 0.2s, background 0.2s;
    }
    .new-page-form input:focus {
      outline: none;
      border-color: #2563eb;
      background: #fff;
    }
    .new-page-form button {
      width: 100%;
      padding: 7px 12px;
      background: #2563eb;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-family: inherit;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }
    .new-page-form button:hover { background: #1d4ed8; }

    /* ---- Right: Editor ---- */
    .editor {
      overflow-y: auto;
      padding: 32px 40px 80px;
      background: #f8fafc;
    }
    .editor-empty {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      color: #94a3b8;
    }
    .editor-empty-icon { font-size: 48px; margin-bottom: 16px; }
    .editor-empty p { font-size: 15px; }

    .editor-title {
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .editor-subtitle {
      font-size: 13px;
      color: #64748b;
      margin-bottom: 28px;
    }

    .field-group {
      margin-bottom: 20px;
    }
    .field-group label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: #475569;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 6px;
    }
    .field-group input[type="text"],
    .field-group select {
      width: 100%;
      padding: 9px 12px;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      font-family: inherit;
      font-size: 14px;
      background: #fff;
      transition: border-color 0.2s;
    }
    .field-group input[type="text"]:focus,
    .field-group select:focus {
      outline: none;
      border-color: #2563eb;
      box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
    }
    .field-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .field-checkbox {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 0;
    }
    .field-checkbox input { width: 16px; height: 16px; cursor: pointer; }
    .field-checkbox label {
      font-size: 14px;
      font-weight: 400;
      color: #1e293b;
      text-transform: none;
      letter-spacing: 0;
      cursor: pointer;
      margin: 0;
    }

    .content-section {
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      padding: 20px 24px;
      margin-bottom: 20px;
    }
    .content-section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .content-section-title {
      font-size: 14px;
      font-weight: 700;
      color: #1e293b;
    }
    .lang-badge {
      font-size: 11px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 4px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .lang-badge.en { background: #dbeafe; color: #1d4ed8; }
    .lang-badge.zh { background: #fce7f3; color: #be185d; }

    .html-textarea {
      width: 100%;
      padding: 10px 12px;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
      font-size: 12px;
      line-height: 1.6;
      resize: vertical;
      min-height: 220px;
      background: #fafafa;
      transition: border-color 0.2s;
    }
    .html-textarea:focus {
      outline: none;
      border-color: #2563eb;
      box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
      background: #fff;
    }

    .preview-btn {
      font-family: inherit;
      font-size: 12px;
      font-weight: 600;
      padding: 5px 12px;
      border-radius: 6px;
      border: 1px solid #e2e8f0;
      background: #f8fafc;
      color: #475569;
      cursor: pointer;
      transition: background 0.15s;
    }
    .preview-btn:hover { background: #f1f5f9; }

    .preview-frame {
      display: none;
      width: 100%;
      height: 300px;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      margin-top: 10px;
    }
    .preview-frame.visible { display: block; }

    .settings-card {
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      padding: 20px 24px;
      margin-bottom: 20px;
    }
    .settings-card-title {
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 16px;
      color: #1e293b;
    }

    .save-bar {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-top: 8px;
    }
    .btn-save {
      padding: 10px 28px;
      background: #2563eb;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: inherit;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-save:hover { background: #1d4ed8; }
    .view-link {
      font-size: 13px;
      color: #2563eb;
      text-decoration: none;
    }
    .view-link:hover { text-decoration: underline; }

    .delete-zone {
      border: 1px solid #fecaca;
      border-radius: 12px;
      padding: 16px 20px;
      background: #fff5f5;
      margin-top: 32px;
    }
    .delete-zone-title {
      font-size: 13px;
      font-weight: 700;
      color: #ef4444;
      margin-bottom: 8px;
    }
    .delete-zone p {
      font-size: 12px;
      color: #64748b;
      margin-bottom: 12px;
    }
    .btn-delete {
      padding: 7px 16px;
      background: #ef4444;
      color: #fff;
      border: none;
      border-radius: 6px;
      font-family: inherit;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-delete:hover { background: #dc2626; }
  </style>
</head>
<body>

  <!-- ===== HEADER ===== -->
  <header class="header">
    <div class="header-logo">NZSEC Admin</div>
    <nav class="header-nav">
      <a href="/admin">Content</a>
      <a href="/admin/pages" class="active">Pages</a>
    </nav>
    <div class="header-actions">
      <a href="/" target="_blank" class="btn-preview">View Site</a>
      <form action="/admin/logout" method="post" style="display:inline">
        <button type="submit" class="btn-logout">Logout</button>
      </form>
    </div>
  </header>

  <% if (saved) { %>
  <div class="save-banner">Page saved successfully.</div>
  <% } %>

  <!-- ===== WORKSPACE ===== -->
  <div class="workspace">

    <!-- ===== LEFT: TREE ===== -->
    <aside class="sidebar">
      <div class="sidebar-header">Pages</div>
      <div class="tree" id="pageTree">
        <%
          // Recursive tree renderer
          function renderTree(pages, parentId, depth) {
            const children = pages
              .filter(p => p.parent === parentId)
              .sort((a, b) => a.order - b.order);
            children.forEach(function(p) {
              const isActive = editPage && editPage.id === p.id;
              const indent = depth * 16;
        %>
        <div class="tree-item <%= isActive ? 'active' : '' %>" style="padding-left: <%= 12 + indent %>px">
          <span class="tree-item-icon"><%= p.showInNav ? '🔗' : '📄' %></span>
          <span class="tree-item-title" title="<%= p.title.en %>"><%= p.title.en %></span>
          <span class="tree-item-slug">/<%= p.slug %></span>
          <div class="tree-item-actions">
            <a href="/admin/pages?edit=<%= p.id %>" class="tree-btn">Edit</a>
            <form action="/admin/pages/reorder?<%= isActive ? 'edit=' + p.id : '' %>" method="post" style="display:inline">
              <input type="hidden" name="id" value="<%= p.id %>">
              <input type="hidden" name="direction" value="up">
              <button type="submit" class="tree-btn" title="Move up">↑</button>
            </form>
            <form action="/admin/pages/reorder?<%= isActive ? 'edit=' + p.id : '' %>" method="post" style="display:inline">
              <input type="hidden" name="id" value="<%= p.id %>">
              <input type="hidden" name="direction" value="down">
              <button type="submit" class="tree-btn" title="Move down">↓</button>
            </form>
          </div>
        </div>
        <%
              renderTree(pages, p.id, depth + 1);
            });
          }
          renderTree(pages, null, 0);
        %>
        <% if (pages.length === 0) { %>
        <div style="padding: 24px 16px; color: #94a3b8; font-size: 13px; text-align: center;">
          No pages yet.<br>Create one below.
        </div>
        <% } %>
      </div>

      <!-- New page quick-create -->
      <div class="new-page-form">
        <div class="new-page-form-title">New Page</div>
        <form action="/admin/pages/create" method="post">
          <input type="text" name="slug" placeholder="slug (e.g. team)" required pattern="[a-zA-Z0-9-]+" title="Letters, numbers and hyphens only">
          <input type="text" name="titleEn" placeholder="Title (EN)">
          <input type="text" name="titleZh" placeholder="标题 (ZH)">
          <button type="submit">+ Create Page</button>
        </form>
      </div>
    </aside>

    <!-- ===== RIGHT: EDITOR ===== -->
    <main class="editor">
      <% if (!editPage) { %>
      <div class="editor-empty">
        <div class="editor-empty-icon">📝</div>
        <p>Select a page to edit, or create a new one.</p>
      </div>
      <% } else { %>

      <div class="editor-title"><%= editPage.title.en %></div>
      <div class="editor-subtitle">/<%= editPage.slug %> &nbsp;·&nbsp; ID: <%= editPage.id %></div>

      <form action="/admin/pages/update" method="post">
        <input type="hidden" name="id" value="<%= editPage.id %>">

        <!-- Settings Card -->
        <div class="settings-card">
          <div class="settings-card-title">Page Settings</div>
          <div class="field-row">
            <div class="field-group">
              <label for="slug">Slug (URL path)</label>
              <input type="text" id="slug" name="slug" value="<%= editPage.slug %>" required pattern="[a-zA-Z0-9-]+" title="Letters, numbers and hyphens only">
            </div>
            <div class="field-group">
              <label for="parent">Parent Page</label>
              <select id="parent" name="parent">
                <option value="">— Top level —</option>
                <% pages.filter(p => p.id !== editPage.id).forEach(function(p) { %>
                <option value="<%= p.id %>" <%= editPage.parent === p.id ? 'selected' : '' %>><%= p.title.en %> (/<%= p.slug %>)</option>
                <% }); %>
              </select>
            </div>
          </div>
          <div class="field-row">
            <div class="field-group">
              <label for="titleEn">Title (English)</label>
              <input type="text" id="titleEn" name="titleEn" value="<%= editPage.title.en %>">
            </div>
            <div class="field-group">
              <label for="titleZh">标题（中文）</label>
              <input type="text" id="titleZh" name="titleZh" value="<%= editPage.title.zh %>">
            </div>
          </div>
          <div class="field-checkbox">
            <input type="checkbox" id="showInNav" name="showInNav" <%= editPage.showInNav ? 'checked' : '' %>>
            <label for="showInNav">Show in navigation bar</label>
          </div>
        </div>

        <!-- EN Content -->
        <div class="content-section">
          <div class="content-section-header">
            <div class="content-section-title">Page Content</div>
            <span class="lang-badge en">EN</span>
          </div>
          <textarea class="html-textarea" id="contentEn" name="contentEn" rows="14" placeholder="Paste your HTML content here…"><%= editPage.content.en %></textarea>
          <div style="margin-top: 8px; display: flex; align-items: center; gap: 8px;">
            <button type="button" class="preview-btn" onclick="togglePreview('previewEn', 'contentEn')">Preview</button>
            <span style="font-size: 12px; color: #94a3b8;">Renders inside site styles</span>
          </div>
          <iframe class="preview-frame" id="previewEn"></iframe>
        </div>

        <!-- ZH Content -->
        <div class="content-section">
          <div class="content-section-header">
            <div class="content-section-title">页面内容</div>
            <span class="lang-badge zh">中文</span>
          </div>
          <textarea class="html-textarea" id="contentZh" name="contentZh" rows="14" placeholder="在此粘贴 HTML 内容…"><%= editPage.content.zh %></textarea>
          <div style="margin-top: 8px; display: flex; align-items: center; gap: 8px;">
            <button type="button" class="preview-btn" onclick="togglePreview('previewZh', 'contentZh')">预览</button>
            <span style="font-size: 12px; color: #94a3b8;">在站点样式中渲染</span>
          </div>
          <iframe class="preview-frame" id="previewZh"></iframe>
        </div>

        <div class="save-bar">
          <button type="submit" class="btn-save">Save Page</button>
          <a href="/<%= editPage.slug %>" target="_blank" class="view-link">View page →</a>
        </div>
      </form>

      <!-- Delete Zone -->
      <div class="delete-zone">
        <div class="delete-zone-title">Danger Zone</div>
        <p>Deleting this page will also delete all child pages. This cannot be undone.</p>
        <form action="/admin/pages/delete" method="post" onsubmit="return confirm('Delete this page and all its children?')">
          <input type="hidden" name="id" value="<%= editPage.id %>">
          <button type="submit" class="btn-delete">Delete Page</button>
        </form>
      </div>

      <% } %>
    </main>
  </div>

  <script>
    function togglePreview(frameId, textareaId) {
      const frame = document.getElementById(frameId);
      const textarea = document.getElementById(textareaId);
      if (frame.classList.contains('visible')) {
        frame.classList.remove('visible');
        return;
      }
      const html = `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>body { padding: 24px; }</style>
</head>
<body data-lang="en">
${textarea.value}
</body>
</html>`;
      frame.srcdoc = html;
      frame.classList.add('visible');
    }
  </script>
</body>
</html>
